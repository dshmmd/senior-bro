# Copy to .env for local dev. The server reads these at boot.
# Postgres (matches docker-compose.yml). Production overrides this.
DATABASE_URL=postgres://senior:senior@localhost:5433/senior_bro

# Deployment mode: local (single implicit owner, no auth) | hosted (accounts)
SENIORBRO_MODE=local

# Required in hosted/production: master key for encrypting secrets at rest.
# Leave unset in local dev (a 0600 keyfile under ~/.senior-bro is auto-generated).
# SENIORBRO_SECRET=change-me-to-a-long-random-string

# Hosted admins (comma-separated emails promoted to admin on sign-in).
# SENIORBRO_ADMIN_EMAILS=you@example.com
