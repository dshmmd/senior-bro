{
  "name": "senior-bro",
  "version": "0.1.0",
  "description": "Local-first AI interview coach. Bring your own key, practice with voice, fix your weaknesses.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "web"
  ],
  "bin": {
    "senior-bro": "server/dist/index.js"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web && npm run build -w server",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node server/dist/index.js",
    "smoke": "node scripts/smoke.mjs",
    "test:guardrail": "node --test 'server/test/*.test.mjs'",
    "e2e": "node e2e/prepare.mjs && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
